{
  "appId": "app.budget.tracker",
  "appName": "Budget",
  "webDir": "dist",
  "server": {
    "androidScheme": "https"
  },
  "ios": {
    "contentInset": "automatic"
  },
  "android": {
    "allowMixedContent": false
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 1000,
      "backgroundColor": "#fafaf7",
      "androidScaleType": "CENTER_CROP",
      "showSpinner": false
    }
  }
}
